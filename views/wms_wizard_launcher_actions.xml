<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================= -->
    <!-- Server actions that open the Odoo-native scan wizard modal    -->
    <!-- for the first order in each queue. The wizard auto-finds the  -->
    <!-- next order via action_open_next_in_queue().                    -->
    <!-- ============================================================= -->

    <record id="server_action_wizard_pick" model="ir.actions.server">
        <field name="name">📦 Open Pick Wizard</field>
        <field name="model_id" ref="model_wms_scan_wizard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_next_in_queue('pick')</field>
    </record>

    <record id="server_action_wizard_pack" model="ir.actions.server">
        <field name="name">🗂 Open Pack Wizard</field>
        <field name="model_id" ref="model_wms_scan_wizard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_next_in_queue('pack')</field>
    </record>

    <record id="server_action_wizard_box" model="ir.actions.server">
        <field name="name">📮 Open Box Wizard</field>
        <field name="model_id" ref="model_wms_scan_wizard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_next_in_queue('box')</field>
    </record>

</odoo>
