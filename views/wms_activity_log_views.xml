<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wms_activity_log_list" model="ir.ui.view">
        <field name="name">wms.activity.log.list</field>
        <field name="model">wms.activity.log</field>
        <field name="arch" type="xml">
            <list string="Activity Log" create="false">
                <field name="create_date"   string="Timestamp"/>
                <field name="kob_user_id"   string="Employee"/>
                <field name="action"        widget="badge"
                       decoration-success="action in ('pick','pack','ship','box')"
                       decoration-danger="action in ('error_pick','error_pack')"
                       decoration-warning="action in ('cancel','return')"
                       decoration-info="action in ('login','logout')"/>
                <field name="ref"           string="Order Ref"/>
                <field name="code"          string="Code Scanned"/>
                <field name="sales_order_id" string="Sales Order" optional="show"/>
                <field name="batch_id"      string="Batch" optional="hide"/>
                <!-- Hidden for clarity — can show via column chooser -->
                <field name="user_id"       string="Odoo Account" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_wms_activity_log_search" model="ir.ui.view">
        <field name="name">wms.activity.log.search</field>
        <field name="model">wms.activity.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="kob_user_id"  string="Employee"/>
                <field name="ref"          string="Order Ref"/>
                <field name="code"         string="Code Scanned"/>
                <filter string="Today"     name="today"
                        domain="[('create_date','&gt;=',context_today().strftime('%Y-%m-%d'))]"/>
                <separator/>
                <filter string="Pick"      name="pick"   domain="[('action','=','pick')]"/>
                <filter string="Pack"      name="pack"   domain="[('action','=','pack')]"/>
                <filter string="Ship"      name="ship"   domain="[('action','=','ship')]"/>
                <filter string="Return"    name="return" domain="[('action','=','return')]"/>
                <filter string="Errors"    name="errors"
                        domain="[('action','in',['error_pick','error_pack'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Employee" name="group_employee"
                            context="{'group_by':'kob_user_id'}"/>
                    <filter string="Action"   name="group_action"
                            context="{'group_by':'action'}"/>
                    <filter string="Date"     name="group_date"
                            context="{'group_by':'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_wms_activity_log_graph" model="ir.ui.view">
        <field name="name">wms.activity.log.graph</field>
        <field name="model">wms.activity.log</field>
        <field name="arch" type="xml">
            <graph string="Activity" type="bar">
                <field name="action"/>
                <field name="kob_user_id" string="Employee"/>
            </graph>
        </field>
    </record>

    <record id="action_wms_activity_log" model="ir.actions.act_window">
        <field name="name">Activity Log</field>
        <field name="res_model">wms.activity.log</field>
        <field name="view_mode">list,graph</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

</odoo>
