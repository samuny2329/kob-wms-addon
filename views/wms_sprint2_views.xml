<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ Quality Check (Outgoing QC) ═══════════════════════════════ -->
    <record id="view_wms_quality_check_list" model="ir.ui.view">
        <field name="name">wms.quality.check.list</field>
        <field name="model">wms.quality.check</field>
        <field name="arch" type="xml">
            <list string="Outgoing QC Checks"
                  decoration-warning="state == 'pending'"
                  decoration-success="state == 'passed'"
                  decoration-danger="state == 'failed'"
                  decoration-muted="state == 'skipped'">
                <field name="wms_order_id"/>
                <field name="product_id"/>
                <field name="lot_id" optional="show"/>
                <field name="expected_qty"/>
                <field name="state" widget="badge"/>
                <field name="checked_by_id" optional="show"/>
                <field name="checked_at" optional="show"/>
                <field name="defect_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_wms_quality_check_form" model="ir.ui.view">
        <field name="name">wms.quality.check.form</field>
        <field name="model">wms.quality.check</field>
        <field name="arch" type="xml">
            <form string="QC Check">
                <header>
                    <button name="action_pass" type="object"
                            string="✅ Pass" class="oe_highlight"
                            invisible="state != 'pending'"/>
                    <button name="action_fail" type="object"
                            string="❌ Fail" class="btn-danger"
                            invisible="state != 'pending'"
                            confirm="Failing will auto-create a defect record and block pack. Continue?"/>
                    <button name="action_skip" type="object"
                            string="⊘ Skip"
                            invisible="state != 'pending'"
                            groups="kob_wms.group_wms_supervisor"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,passed,failed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="wms_order_id"/>
                            <field name="wms_line_id"/>
                            <field name="product_id"/>
                            <field name="lot_id"/>
                            <field name="expected_qty"/>
                        </group>
                        <group>
                            <field name="checked_by_id" readonly="1"/>
                            <field name="checked_at" readonly="1"/>
                            <field name="defect_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="QC Notes">
                        <field name="check_notes" nolabel="1"
                               placeholder="Record what was checked, what was found..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_wms_quality_check" model="ir.actions.act_window">
        <field name="name">Outgoing QC Checks</field>
        <field name="res_model">wms.quality.check</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_pending': 1}</field>
    </record>

    <!-- ═══ KPI Alert Rule ════════════════════════════════════════════ -->
    <record id="view_wms_kpi_alert_rule_list" model="ir.ui.view">
        <field name="name">wms.kpi.alert.rule.list</field>
        <field name="model">wms.kpi.alert.rule</field>
        <field name="arch" type="xml">
            <list string="KPI Alert Rules">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="metric_code"/>
                <field name="operator"/>
                <field name="threshold"/>
                <field name="frequency"/>
                <field name="notify_group_id" optional="show"/>
                <field name="last_value" optional="show"/>
                <field name="last_triggered_at" optional="show"/>
                <field name="trigger_count" optional="show"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_wms_kpi_alert_rule_form" model="ir.ui.view">
        <field name="name">wms.kpi.alert.rule.form</field>
        <field name="model">wms.kpi.alert.rule</field>
        <field name="arch" type="xml">
            <form string="KPI Alert Rule">
                <header>
                    <button name="action_evaluate" type="object"
                            string="🔍 Evaluate Now" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Daily SLA Pick &lt; 90%"/></h1>
                    </div>
                    <group>
                        <group string="Rule">
                            <field name="metric_code"/>
                            <field name="operator"/>
                            <field name="threshold"/>
                            <field name="frequency"/>
                            <field name="active"/>
                        </group>
                        <group string="Notification">
                            <field name="notify_channel"/>
                            <field name="notify_group_id"/>
                        </group>
                    </group>
                    <group string="Context / Description">
                        <field name="description" nolabel="1"
                               placeholder="What does a breach mean? What action should be taken?"/>
                    </group>
                    <group string="Stats">
                        <group>
                            <field name="last_evaluated_at" readonly="1"/>
                            <field name="last_value" readonly="1"/>
                        </group>
                        <group>
                            <field name="last_triggered_at" readonly="1"/>
                            <field name="trigger_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_wms_kpi_alert_rule" model="ir.actions.act_window">
        <field name="name">KPI Alert Rules</field>
        <field name="res_model">wms.kpi.alert.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- ═══ Product Template — add QC Required toggle to list ═════════ -->
    <record id="view_product_template_qc_list" model="ir.ui.view">
        <field name="name">product.template.qc.list</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='categ_id']" position="after">
                <field name="qc_required_outgoing"
                       string="Outgoing QC"
                       optional="hide"
                       widget="boolean"/>
            </xpath>
        </field>
    </record>

    <!-- Server actions for bulk toggling Outgoing QC flag -->
    <record id="action_set_qc_required_true" model="ir.actions.server">
        <field name="name">🎯 เปิด: Outgoing QC Required</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.write({'qc_required_outgoing': True})</field>
    </record>

    <record id="action_set_qc_required_false" model="ir.actions.server">
        <field name="name">❌ ปิด: Outgoing QC Required</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">records.write({'qc_required_outgoing': False})</field>
    </record>

</odoo>
