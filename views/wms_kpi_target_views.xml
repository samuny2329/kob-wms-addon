    <record id="access_wms_kpi_assessment_line_worker" model="ir.model.access">
        <field name="name">wms.kpi.assessment.line.worker</field>
        <field name="model_id" ref="model_wms_kpi_assessment_line"/>
        <field name="group_id" ref="group_wms_worker"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
    </record>
    <record id="access_wms_kpi_assessment_line_manager" model="ir.model.access">
        <field name="name">wms.kpi.assessment.line.manager</field>
        <field name="model_id" ref="model_wms_kpi_assessment_line"/>
        <field name="group_id" ref="group_wms_manager"/>
        <field name="perm_read" eval="True"/>
