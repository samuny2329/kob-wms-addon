<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wms_rack_list" model="ir.ui.view">
        <field name="name">wms.rack.list</field>
        <field name="model">wms.rack</field>
        <field name="arch" type="xml">
            <list string="Racks" decoration-danger="frozen == True">
                <field name="code"/>
                <field name="name"/>
                <field name="zone_id"/>
                <field name="location_id"/>
                <field name="capacity"/>
                <field name="frozen" widget="boolean_toggle"/>
                <field name="frozen_reason"/>
            </list>
        </field>
    </record>

    <record id="view_wms_rack_form" model="ir.ui.view">
        <field name="name">wms.rack.form</field>
        <field name="model">wms.rack</field>
        <field name="arch" type="xml">
            <form string="Rack">
                <header>
                    <button name="action_toggle_freeze" type="object"
                            string="Toggle Freeze" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Rack name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="zone_id"/>
                            <field name="location_id"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="frozen"/>
                            <field name="frozen_reason" invisible="not frozen"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_wms_rack" model="ir.actions.act_window">
        <field name="name">Racks</field>
        <field name="res_model">wms.rack</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first Rack</p>
            <p>Bulk storage racks belong to zones and can be frozen to block transfers.</p>
        </field>
    </record>

</odoo>
