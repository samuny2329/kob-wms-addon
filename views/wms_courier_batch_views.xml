<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wms_courier_batch_list" model="ir.ui.view">
        <field name="name">wms.courier.batch.list</field>
        <field name="model">wms.courier.batch</field>
        <field name="arch" type="xml">
            <list string="Courier Batches"
                  decoration-info="state == 'scanning'"
                  decoration-success="state == 'dispatched'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="work_date"/>
                <field name="courier_id"/>
                <field name="scanned_count"/>
                <field name="dispatched_at"/>
                <field name="dispatched_by"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_wms_courier_batch_form" model="ir.ui.view">
        <field name="name">wms.courier.batch.form</field>
        <field name="model">wms.courier.batch</field>
        <field name="arch" type="xml">
            <form string="Courier Batch">
                <header>
                    <button name="action_start_scanning" type="object"
                            string="Start Scanning" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_dispatch" type="object"
                            string="Dispatch" class="oe_highlight"
                            invisible="state != 'scanning'"/>
                    <button name="action_cancel" type="object" string="Cancel"
                            invisible="state in ('dispatched', 'cancelled')"/>
                    <button name="action_draft" type="object" string="Reset"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,scanning,dispatched"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="courier_id"/>
                            <field name="work_date"/>
                            <field name="scanned_count"/>
                        </group>
                        <group>
                            <field name="receiver_name"/>
                            <field name="dispatched_at" readonly="1"/>
                            <field name="dispatched_by" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Scanned Items">
                            <field name="scan_item_ids">
                                <list>
                                    <field name="barcode"/>
                                    <field name="order_ref"/>
                                    <field name="shop_name"/>
                                    <field name="scanned_at"/>
                                    <field name="scanned_by"/>
                                </list>
                            </field>
                        </page>
                        <page string="Signature">
                            <field name="signature" widget="image"/>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_wms_courier_batch" model="ir.actions.act_window">
        <field name="name">Dispatch Batches</field>
        <field name="res_model">wms.courier.batch</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first dispatch batch</p>
            <p>Group outbound scans by courier, capture signature, and close for dispatch (F4 shortcut).</p>
        </field>
    </record>

    <record id="view_wms_scan_item_list" model="ir.ui.view">
        <field name="name">wms.scan.item.list</field>
        <field name="model">wms.scan.item</field>
        <field name="arch" type="xml">
            <list string="Scanned Items">
                <field name="scanned_at"/>
                <field name="barcode"/>
                <field name="courier_id"/>
                <field name="batch_id"/>
                <field name="order_ref"/>
                <field name="shop_name"/>
                <field name="scanned_by"/>
            </list>
        </field>
    </record>

    <record id="view_wms_scan_item_form" model="ir.ui.view">
        <field name="name">wms.scan.item.form</field>
        <field name="model">wms.scan.item</field>
        <field name="arch" type="xml">
            <form string="Scan Item">
                <sheet>
                    <group>
                        <group>
                            <field name="barcode"/>
                            <field name="courier_id"/>
                            <field name="batch_id"/>
                            <field name="sales_order_id"/>
                        </group>
                        <group>
                            <field name="order_ref"/>
                            <field name="shop_name"/>
                            <field name="expected_qty"/>
                            <field name="scanned_qty"/>
                            <field name="scanned_at"/>
                            <field name="scanned_by"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_wms_scan_item_search" model="ir.ui.view">
        <field name="name">wms.scan.item.search</field>
        <field name="model">wms.scan.item</field>
        <field name="arch" type="xml">
            <search>
                <field name="barcode"/>
                <field name="order_ref"/>
                <field name="shop_name"/>
                <field name="courier_id"/>
                <filter string="Today" name="today"
                        domain="[('scanned_at', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter string="Courier" name="group_courier"
                            context="{'group_by': 'courier_id'}"/>
                    <filter string="Batch" name="group_batch"
                            context="{'group_by': 'batch_id'}"/>
                    <filter string="Shop" name="group_shop"
                            context="{'group_by': 'shop_name'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_wms_scan_item" model="ir.actions.act_window">
        <field name="name">Scanned Items</field>
        <field name="res_model">wms.scan.item</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_today': 1}</field>
    </record>

</odoo>
