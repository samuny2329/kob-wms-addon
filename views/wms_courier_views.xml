<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wms_courier_list" model="ir.ui.view">
        <field name="name">wms.courier.list</field>
        <field name="model">wms.courier</field>
        <field name="arch" type="xml">
            <list string="Couriers" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="color_hex"/>
                <field name="tracking_url_template"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_wms_courier_form" model="ir.ui.view">
        <field name="name">wms.courier.form</field>
        <field name="model">wms.courier</field>
        <field name="arch" type="xml">
            <form string="Courier">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="color_hex"/>
                            <field name="sequence"/>
                        </group>
                        <group>
                            <field name="tracking_url_template"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_wms_courier" model="ir.actions.act_window">
        <field name="name">Couriers</field>
        <field name="res_model">wms.courier</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
