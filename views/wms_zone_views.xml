<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wms_zone_list" model="ir.ui.view">
        <field name="name">wms.zone.list</field>
        <field name="model">wms.zone</field>
        <field name="arch" type="xml">
            <list string="Zones">
                <field name="code"/>
                <field name="name"/>
                <field name="warehouse_id"/>
                <field name="rack_count"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_wms_zone_form" model="ir.ui.view">
        <field name="name">wms.zone.form</field>
        <field name="model">wms.zone</field>
        <field name="arch" type="xml">
            <form string="Zone">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Zone name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="warehouse_id"/>
                            <field name="color_hex" widget="char"/>
                        </group>
                        <group>
                            <field name="rack_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Racks">
                            <field name="rack_ids">
                                <list editable="bottom">
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="capacity"/>
                                    <field name="frozen"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_wms_zone_kanban" model="ir.ui.view">
        <field name="name">wms.zone.kanban</field>
        <field name="model">wms.zone</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="code"/>
                <field name="rack_count"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong><field name="code"/></strong> — <field name="name"/>
                                </div>
                            </div>
                            <div>
                                <span>Racks: <field name="rack_count"/></span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_wms_zone" model="ir.actions.act_window">
        <field name="name">Zones</field>
        <field name="res_model">wms.zone</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first WMS Zone</p>
            <p>Zones group racks and pickfaces by area (e.g. A, B, C, FLG).</p>
        </field>
    </record>

</odoo>
