<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_qc_monthly" model="ir.actions.report">
        <field name="name">QC Monthly Report</field>
        <field name="model">wms.qc.monthly.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">kob_wms.qc_monthly_report_template</field>
        <field name="report_file">kob_wms.qc_monthly_report_template</field>
        <field name="binding_model_id" ref="model_wms_qc_monthly_report"/>
        <field name="binding_type">report</field>
    </record>

    <template id="qc_monthly_report_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.internal_layout">
                    <div class="page">
                        <h2>🎯 QC Monthly Report — <t t-esc="doc.period_month"/></h2>
                        <p>
                            <strong>Period:</strong>
                            <t t-esc="doc.period_start"/> → <t t-esc="doc.period_end"/>
                        </p>

                        <h3>📊 Summary</h3>
                        <table class="table table-sm">
                            <thead>
                                <tr style="background-color:#f0f0f0">
                                    <th>Metric</th>
                                    <th class="text-right">Value</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td>Total Defects</td>
                                    <td class="text-right"><t t-esc="doc.total_defects"/></td></tr>
                                <tr><td>🔴 Critical</td>
                                    <td class="text-right"><t t-esc="doc.critical_defects"/></td></tr>
                                <tr><td>🟠 High</td>
                                    <td class="text-right"><t t-esc="doc.high_defects"/></td></tr>
                                <tr><td>✅ Closed</td>
                                    <td class="text-right"><t t-esc="doc.closed_defects"/></td></tr>
                                <tr><td>Avg Resolution Days</td>
                                    <td class="text-right">
                                        <t t-esc="'%.1f' % doc.avg_resolution_days"/>
                                    </td></tr>
                            </tbody>
                        </table>

                        <h3>🏷️ Top Offender</h3>
                        <p>
                            <strong><t t-esc="doc.top_product_name or '—'"/></strong>
                            · <t t-esc="doc.top_product_count"/> defects
                        </p>

                        <h3>🗂️ By Type</h3>
                        <pre style="background:#f8f8f8;padding:8px">
                            <t t-esc="doc.defects_by_type or '—'"/>
                        </pre>

                        <h3>📋 Defect List</h3>
                        <table class="table table-sm">
                            <thead>
                                <tr style="background-color:#f0f0f0">
                                    <th>Date</th>
                                    <th>Product</th>
                                    <th>Type</th>
                                    <th>Severity</th>
                                    <th>State</th>
                                    <th>Resolution</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="doc.defect_ids" t-as="d">
                                    <td><t t-esc="d.report_date.strftime('%Y-%m-%d') if d.report_date else ''"/></td>
                                    <td><t t-esc="d.product_id.display_name"/></td>
                                    <td><t t-esc="dict(d._fields['defect_type'].selection).get(d.defect_type,'')"/></td>
                                    <td><t t-esc="dict(d._fields['severity'].selection).get(d.severity,'')"/></td>
                                    <td><t t-esc="dict(d._fields['state'].selection).get(d.state,'')"/></td>
                                    <td><t t-esc="dict(d._fields['resolution'].selection).get(d.resolution,'')"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <p style="margin-top:30px;font-size:10px;color:#888">
                            Auto-generated by KOB WMS · QC Monthly Report Cron
                        </p>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
