<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════
         Count Session Summary Report — QWeb PDF
         Bound to wms.count.session; shows all adjustments with variance
         ═══════════════════════════════════════════════════════════════ -->

    <template id="report_wms_count_session">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="session">
                <t t-call="web.external_layout">
                    <div class="page">

                        <!-- ── Title ─────────────────────────────── -->
                        <div class="text-center mb-4">
                            <h2>Inventory Count — Adjustment Summary</h2>
                            <h4 class="text-muted" t-esc="session.name"/>
                        </div>

                        <!-- ── Session Info ───────────────────────── -->
                        <div class="row mb-4">
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width:40%"><strong>Type:</strong></td>
                                        <td t-esc="dict(session.fields_get(['session_type'])['session_type']['selection'])[session.session_type]"/>
                                    </tr>
                                    <tr>
                                        <td><strong>Warehouse:</strong></td>
                                        <td t-field="session.warehouse_id"/>
                                    </tr>
                                    <tr>
                                        <td><strong>Responsible:</strong></td>
                                        <td t-field="session.responsible_id"/>
                                    </tr>
                                    <tr>
                                        <td><strong>State:</strong></td>
                                        <td t-esc="dict(session.fields_get(['state'])['state']['selection'])[session.state]"/>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <table class="table table-sm table-borderless">
                                    <tr>
                                        <td style="width:40%"><strong>Start Date:</strong></td>
                                        <td t-field="session.date_start"
                                            t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                    </tr>
                                    <tr>
                                        <td><strong>End Date:</strong></td>
                                        <td t-field="session.date_end"
                                            t-options='{"widget": "datetime", "format": "dd/MM/yyyy HH:mm"}'/>
                                    </tr>
                                    <tr>
                                        <td><strong>Tasks:</strong></td>
                                        <td>
                                            <t t-esc="session.done_count"/> done /
                                            <t t-esc="session.task_count"/> total
                                        </td>
                                    </tr>
                                    <tr>
                                        <td><strong>Adjustments:</strong></td>
                                        <td t-esc="session.adjustment_count"/>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ── Summary KPIs ───────────────────────── -->
                        <t t-set="adjs" t-value="session.adjustment_ids.filtered(lambda a: a.state != 'rejected')"/>
                        <t t-set="variance_adjs" t-value="adjs.filtered(lambda a: a.variance_qty != 0)"/>
                        <t t-set="high_variance_adjs" t-value="adjs.filtered(lambda a: abs(a.variance_pct) > 5)"/>

                        <div class="row mb-4 text-center">
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="fs-4 fw-bold" t-esc="len(adjs)"/>
                                    <div class="text-muted small">Total SKU Lines</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="fs-4 fw-bold text-warning" t-esc="len(variance_adjs)"/>
                                    <div class="text-muted small">Lines with Variance</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="fs-4 fw-bold text-danger" t-esc="len(high_variance_adjs)"/>
                                    <div class="text-muted small">High Variance (&gt;5%)</div>
                                </div>
                            </div>
                            <div class="col-3">
                                <div class="border rounded p-2">
                                    <div class="fs-4 fw-bold" t-esc="len(adjs.filtered(lambda a: a.state == 'applied'))"/>
                                    <div class="text-muted small">Applied</div>
                                </div>
                            </div>
                        </div>

                        <!-- ── Adjustments Table ──────────────────── -->
                        <h5 class="mt-3">Adjustment Lines</h5>

                        <t t-if="not adjs">
                            <p class="text-muted fst-italic">No adjustments for this session.</p>
                        </t>

                        <t t-if="adjs">
                            <table class="table table-sm table-bordered" style="font-size:10pt">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Ref.</th>
                                        <th>Location</th>
                                        <th>Product</th>
                                        <th>Lot / Serial</th>
                                        <th class="text-end">System Qty</th>
                                        <th class="text-end">Counted Qty</th>
                                        <th class="text-end">Variance</th>
                                        <th class="text-end">Var %</th>
                                        <th class="text-center">State</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <!-- Group by location for readability -->
                                    <t t-set="locations" t-value="adjs.mapped('location_id')"/>
                                    <t t-foreach="locations" t-as="loc">
                                        <!-- Location header row -->
                                        <tr class="table-secondary">
                                            <td colspan="9">
                                                <strong>
                                                    <i class="fa fa-map-marker me-1"/>
                                                    <t t-esc="loc.display_name"/>
                                                </strong>
                                            </td>
                                        </tr>
                                        <!-- Lines for this location -->
                                        <t t-set="loc_adjs" t-value="adjs.filtered(lambda a: a.location_id.id == loc.id)"/>
                                        <t t-foreach="loc_adjs" t-as="adj">
                                            <tr t-att-style="'background:#fff3cd' if abs(adj.variance_pct) > 5 and adj.variance_qty != 0 else ('background:#d1e7dd' if adj.variance_qty == 0 else '')">
                                                <td t-esc="adj.name" style="font-size:8pt;color:#666"/>
                                                <td/>
                                                <td>
                                                    <span t-esc="adj.product_id.display_name"/>
                                                    <br/>
                                                    <small class="text-muted" t-esc="adj.product_id.default_code or ''"/>
                                                </td>
                                                <td t-esc="adj.lot_id.name or '—'"/>
                                                <td class="text-end" t-esc="'%.2f' % adj.system_qty"/>
                                                <td class="text-end" t-esc="'%.2f' % adj.counted_qty"/>
                                                <td class="text-end"
                                                    t-att-style="'color:#dc3545;font-weight:bold' if adj.variance_qty != 0 else 'color:#198754'">
                                                    <t t-esc="'%+.2f' % adj.variance_qty"/>
                                                </td>
                                                <td class="text-end"
                                                    t-att-style="'color:#dc3545;font-weight:bold' if abs(adj.variance_pct) > 5 else ''">
                                                    <t t-esc="'%+.1f%%' % adj.variance_pct"/>
                                                </td>
                                                <td class="text-center">
                                                    <span t-esc="adj.state.capitalize()"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                                <!-- Totals footer -->
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="4">TOTAL</td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % sum(adjs.mapped('system_qty'))"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'%.2f' % sum(adjs.mapped('counted_qty'))"/>
                                        </td>
                                        <td class="text-end">
                                            <t t-esc="'%+.2f' % sum(adjs.mapped('variance_qty'))"/>
                                        </td>
                                        <td colspan="2"/>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ── Rejected Lines (if any) ────────────── -->
                        <t t-set="rejected" t-value="session.adjustment_ids.filtered(lambda a: a.state == 'rejected')"/>
                        <t t-if="rejected">
                            <p class="text-muted small mt-3">
                                <strong>Rejected:</strong>
                                <t t-esc="len(rejected)"/> line(s) rejected and excluded from totals above.
                            </p>
                        </t>

                        <!-- ── Tasks breakdown ────────────────────── -->
                        <h5 class="mt-4">Task Breakdown</h5>
                        <table class="table table-sm table-bordered" style="font-size:10pt">
                            <thead class="table-light">
                                <tr>
                                    <th>Task</th>
                                    <th>Location</th>
                                    <th>Worker</th>
                                    <th class="text-end">Expected</th>
                                    <th class="text-end">Counted</th>
                                    <th class="text-end">Variance</th>
                                    <th class="text-center">State</th>
                                    <th class="text-end">Adj.</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="session.task_ids" t-as="task">
                                    <tr>
                                        <td t-esc="task.name" style="font-size:8pt"/>
                                        <td t-esc="task.location_id.display_name"/>
                                        <td t-esc="task.assigned_user_id.name or '(broadcast)'"/>
                                        <td class="text-end" t-esc="'%.2f' % (task.expected_qty or 0)"/>
                                        <td class="text-end" t-esc="'%.2f' % (task.counted_qty or 0)"/>
                                        <td class="text-end" t-esc="'%+.2f' % (task.variance or 0)"/>
                                        <td class="text-center" t-esc="task.state.capitalize()"/>
                                        <td class="text-end" t-esc="task.adjustment_count"/>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- ── Footer note ────────────────────────── -->
                        <div class="mt-4 text-muted small border-top pt-2">
                            <em>
                                Printed on
                                <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                — KOB WMS Pro
                            </em>
                        </div>

                    </div><!-- /page -->
                </t><!-- /external_layout -->
            </t><!-- /foreach -->
        </t><!-- /html_container -->
    </template>

</odoo>
