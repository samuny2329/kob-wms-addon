<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_wms_awb_label">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page" style="font-family: sans-serif; padding: 4mm;">
                        <div style="border: 2px solid #000; padding: 3mm; height: 140mm;">
                            <!-- Header -->
                            <div style="text-align: center; font-size: 11pt; font-weight: bold; border-bottom: 2px solid #000; padding-bottom: 2mm; margin-bottom: 2mm;">
                                <span t-field="o.courier_id.name"/>
                            </div>

                            <!-- From / To -->
                            <div style="font-size: 8pt; line-height: 1.3; margin-bottom: 2mm;">
                                <strong>FROM:</strong><br/>
                                KOB (Kiss of Beauty Co., Ltd.)<br/>
                                Warehouse Hub
                            </div>
                            <div style="font-size: 8pt; line-height: 1.3; border-top: 1px dashed #000; padding-top: 2mm; margin-bottom: 2mm;">
                                <strong>TO:</strong><br/>
                                <span t-field="o.customer"/>
                                <br/>
                                <t t-if="o.partner_id">
                                    <span t-field="o.partner_id.street"/><br/>
                                    <span t-field="o.partner_id.city"/>
                                    <span t-field="o.partner_id.zip"/>
                                    <br/>
                                    Tel: <span t-field="o.partner_id.phone"/>
                                </t>
                            </div>

                            <!-- Order ref -->
                            <div style="font-size: 8pt; border-top: 1px dashed #000; padding-top: 2mm; margin-bottom: 2mm;">
                                <strong>Order:</strong>
                                <span t-field="o.ref"/>
                                <br/>
                                <strong>Platform:</strong>
                                <span t-field="o.platform"/>
                                <br/>
                                <strong>Items:</strong>
                                <span t-field="o.expected_total"/>
                            </div>

                            <!-- AWB barcode -->
                            <div style="text-align: center; border: 1px solid #000; padding: 3mm; margin-top: 2mm;">
                                <div style="font-size: 9pt;"><strong>AWB / Tracking</strong></div>
                                <div style="font-size: 11pt; font-weight: bold; margin: 1mm 0;">
                                    <span t-field="o.awb"/>
                                </div>
                                <img t-if="o.awb"
                                     t-attf-src="/report/barcode/Code128/{{o.awb}}?width=340&amp;height=70"
                                     style="max-width: 100%;"/>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
