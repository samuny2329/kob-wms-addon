<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Deactivated in v2.22 — user removed Automation Audit from UI.
         noupdate="0" so -u flips existing cron to active=False.
         Model code + view kept for future reactivation via Developer mode. -->
    <data noupdate="0">

        <record id="ir_cron_monthly_automation_audit" model="ir.cron">
            <field name="name">WMS · Monthly Automation Audit (K-OKR3-02)</field>
            <field name="model_id" ref="model_wms_automation_audit"/>
            <field name="state">code</field>
            <field name="code">model.cron_monthly_audit()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
