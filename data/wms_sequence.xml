<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_wms_count_session" model="ir.sequence">
            <field name="name">WMS Count Session</field>
            <field name="code">wms.count.session</field>
            <field name="prefix">FC/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_wms_count_task" model="ir.sequence">
            <field name="name">WMS Count Task</field>
            <field name="code">wms.count.task</field>
            <field name="prefix">CT/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_wms_count_adjustment" model="ir.sequence">
            <field name="name">WMS Count Adjustment</field>
            <field name="code">wms.count.adjustment</field>
            <field name="prefix">ADJ/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_wms_sales_order" model="ir.sequence">
            <field name="name">WMS Sales Order</field>
            <field name="code">wms.sales.order</field>
            <field name="prefix">SO/%(year)s/</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_wms_courier_batch" model="ir.sequence">
            <field name="name">WMS Courier Batch</field>
            <field name="code">wms.courier.batch</field>
            <field name="prefix">BCH-</field>
            <field name="padding">6</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
