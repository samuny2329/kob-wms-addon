<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Runs every 5 minutes; each config's sync_interval_minutes is
             honoured inside the method (so platform A syncs every 15min,
             platform B every 60min — all driven by the same cron). -->
        <record id="ir_cron_platform_auto_sync" model="ir.cron">
            <field name="name">WMS · Platform Auto-Sync (Shopee/Lazada/TikTok)</field>
            <field name="model_id" ref="model_wms_api_config"/>
            <field name="state">code</field>
            <field name="code">model.cron_auto_sync()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="False"/>
        </record>

    </data>
</odoo>
