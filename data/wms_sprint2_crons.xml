<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily KPI alert rule evaluator at 08:00 -->
        <record id="ir_cron_kpi_alert_rule" model="ir.cron">
            <field name="name">WMS · Daily KPI Alert Rule Evaluator</field>
            <field name="model_id" ref="model_wms_kpi_alert_rule"/>
            <field name="state">code</field>
            <field name="code">model.cron_evaluate_all()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
