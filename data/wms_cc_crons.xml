<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Daily reorder critical check at 05:30 -->
        <record id="ir_cron_reorder_critical" model="ir.cron">
            <field name="name">CC · Daily Reorder Critical Shortage Alert</field>
            <field name="model_id" ref="model_wms_cc_reorder_monitor"/>
            <field name="state">code</field>
            <field name="code">model.cron_check_critical()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

        <!-- Daily PO overdue scan at 09:00 -->
        <record id="ir_cron_po_reminder" model="ir.cron">
            <field name="name">CC · Daily PO Overdue Reminder</field>
            <field name="model_id" ref="model_wms_cc_po_reminder"/>
            <field name="state">code</field>
            <field name="code">model.cron_scan_overdue_pos()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>

    </data>
</odoo>
