<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!--
            Daily Cycle Count — runs at 06:00 every morning.
            Creates a Cycle Count session, generates ABC tasks,
            starts the session, and broadcasts tasks to all workers
            so they appear in Count (F5) without manual assignment.

            Managers can override via Settings > Technical > Scheduled Actions.
        -->
        <record id="ir_cron_auto_cycle_count" model="ir.cron">
            <field name="name">WMS: Auto Cycle Count (Daily 06:00)</field>
            <field name="model_id" ref="model_wms_count_session"/>
            <field name="state">code</field>
            <field name="code">model.action_auto_cycle_count()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active">True</field>
            <field name="nextcall" eval="(datetime.now() + timedelta(days=1)).replace(hour=6, minute=0, second=0, microsecond=0).strftime('%Y-%m-%d %H:%M:%S')"/>
        </record>

    </data>
</odoo>
