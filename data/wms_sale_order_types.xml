<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- Access rules -->
    <record id="access_sale_order_type_worker" model="ir.model.access">
        <field name="name">sale.order.type.worker</field>
        <field name="model_id" ref="model_sale_order_type"/>
        <field name="group_id" ref="group_wms_worker"/>
        <field name="perm_read" eval="True"/>
    </record>
    <record id="access_sale_order_type_manager" model="ir.model.access">
        <field name="name">sale.order.type.manager</field>
        <field name="model_id" ref="model_sale_order_type"/>
        <field name="group_id" ref="group_wms_manager"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Order Types from UAT -->
    <record id="sot_normal" model="sale.order.type">
        <field name="name">Normal Order</field>
    </record>
    <record id="sot_consignment" model="sale.order.type">
        <field name="name">Consignment Order</field>
    </record>
    <record id="sot_return" model="sale.order.type">
        <field name="name">Return Order</field>
    </record>
    <record id="sot_direct_return" model="sale.order.type">
        <field name="name">Direct Return Order</field>
    </record>
    <record id="sot_sampling" model="sale.order.type">
        <field name="name">Sampling Order</field>
    </record>
    <record id="sot_adj_inventory" model="sale.order.type">
        <field name="name">Adj Inventory</field>
    </record>
    <record id="sot_assets" model="sale.order.type">
        <field name="name">Assets</field>
    </record>

</odoo>
