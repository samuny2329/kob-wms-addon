<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="kob_wms.WmsCountScreen">
<div class="sap-root">

    <!-- ── GLOBAL LOADING ─────────────────────────────────────────────── -->
    <div t-if="state.loading" class="sap-loading">
        <span class="wms-count-spinner"/>
        <span>กำลังโหลด…</span>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         SCREEN 1 — LIST REPORT (SAP Fiori List Report)
    ══════════════════════════════════════════════════════════════════════ -->
    <div t-elif="state.screen === 'tasks'" class="sap-page">

        <!-- Shell bar -->
        <div class="sap-shellbar">
            <button class="sap-shellbar-btn" t-on-click="() => goToMode('kob_wms.action_wms_login_screen')" title="Home">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            </button>
            <div class="sap-shellbar-logo">KOB WMS</div>
            <div class="sap-shellbar-title">งานนับสินค้า</div>
            <div class="sap-shellbar-spacer"/>
            <button class="sap-shellbar-btn" t-on-click="loadTasks" title="Refresh">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
            </button>
        </div>

        <!-- Toolbar (table-level) -->
        <div class="sap-toolbar">
            <span class="sap-toolbar-title">
                งานรอดำเนินการ
                <span class="sap-count-badge"><t t-esc="state.tasks.length"/></span>
            </span>
            <div class="sap-toolbar-actions"/>
        </div>

        <!-- Empty -->
        <div t-if="state.tasks.length === 0" class="sap-no-data">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" opacity=".3"><circle cx="12" cy="12" r="10"/><polyline points="20 6 9 17 4 12"/></svg>
            <p>ไม่มีงานนับที่ได้รับมอบหมาย</p>
        </div>

        <!-- SAP Analytical Table -->
        <div t-else="" class="sap-table-wrap sap-table-flex">
            <table class="sap-table">
                <thead>
                    <tr>
                        <th class="sap-th sap-th-task">งาน / Task</th>
                        <th class="sap-th sap-th-loc">Zone</th>
                        <th class="sap-th sap-th-loc">Rack → Location</th>
                        <th class="sap-th sap-th-num">สินค้า</th>
                        <th class="sap-th sap-th-session">Session</th>
                        <th class="sap-th sap-th-action"/>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="state.tasks" t-as="task" t-key="task.id"
                        class="sap-tr" t-on-click="() => selectTask(task)">
                        <td class="sap-td">
                            <span class="sap-task-name" t-esc="task.name"/>
                        </td>
                        <td class="sap-td">
                            <span class="sap-zone-tag" t-esc="task.zone_code or task.zone_name"/>
                        </td>
                        <td class="sap-td">
                            <span class="sap-text-muted" t-esc="task.rack_name"/>
                            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                            <strong t-esc="task.location_name"/>
                        </td>
                        <td class="sap-td sap-ta-center">
                            <span class="sap-num-chip" t-esc="task.product_count"/>
                        </td>
                        <td class="sap-td sap-text-muted" t-esc="task.session_name or '—'"/>
                        <td class="sap-td sap-td-action">
                            <button class="sap-btn-ghost-sm">
                                เริ่มนับ
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                            </button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
        <!-- Footer status bar -->
        <div class="sap-statusbar">
            <span><t t-esc="state.tasks.length"/> รายการ</span>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         SCREEN 2 — NAVIGATE (Object Page — Location Details)
    ══════════════════════════════════════════════════════════════════════ -->
    <div t-elif="state.screen === 'navigate'" class="sap-page">

        <div class="sap-shellbar">
            <button class="sap-shellbar-btn" t-on-click="backToTasks">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="sap-shellbar-logo">KOB WMS</div>
            <div class="sap-shellbar-title">นำทาง</div>
            <div class="sap-shellbar-spacer"/>
            <div class="sap-step-wrap">
                <span class="sap-step sap-step-on">1</span>
                <span class="sap-step-line"/>
                <span class="sap-step">2</span>
                <span class="sap-step-line"/>
                <span class="sap-step">3</span>
            </div>
        </div>

        <!-- Object Header -->
        <div class="sap-obj-header">
            <div class="sap-obj-breadcrumb">
                <span t-esc="state.task.zone_code or state.task.zone_name"/>
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                <span t-esc="state.task.rack_name"/>
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                <strong t-esc="state.task.location_name"/>
            </div>
            <div class="sap-obj-title" t-esc="state.task.location_name"/>
            <div class="sap-obj-attrs">
                <span class="sap-attr"><span class="sap-attr-label">Zone</span><span class="sap-attr-val" t-esc="state.task.zone_code or state.task.zone_name"/></span>
                <span class="sap-attr-sep"/>
                <span class="sap-attr"><span class="sap-attr-label">Rack</span><span class="sap-attr-val" t-esc="state.task.rack_name"/></span>
                <span class="sap-attr-sep"/>
                <span class="sap-attr"><span class="sap-attr-label">สินค้า</span><span class="sap-attr-val"><t t-esc="state.products.length"/> รายการ</span></span>
            </div>
        </div>

        <!-- Section: Products to count -->
        <div class="sap-toolbar">
            <span class="sap-toolbar-title">
                สินค้าที่ต้องนับ
                <span class="sap-count-badge"><t t-esc="state.products.length"/></span>
            </span>
        </div>

        <div class="sap-table-wrap sap-table-flex">
            <div t-if="state.products.length === 0" class="sap-no-data">
                <p>ไม่มีสินค้าในระบบสำหรับตำแหน่งนี้</p>
            </div>
            <table t-else="" class="sap-table">
                <thead>
                    <tr>
                        <th class="sap-th">SKU</th>
                        <th class="sap-th">ชื่อสินค้า</th>
                        <th class="sap-th sap-ta-center">Lot</th>
                    </tr>
                </thead>
                <tbody>
                    <tr t-foreach="state.products" t-as="p" t-key="p.product_id" class="sap-tr sap-tr-noclick">
                        <td class="sap-td"><span class="sap-mono" t-esc="p.product_code or '—'"/></td>
                        <td class="sap-td sap-td-name" t-esc="p.product_name"/>
                        <td class="sap-td sap-ta-center"><span class="sap-num-chip" t-esc="p.lots.length"/></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="sap-obj-footer">
            <button class="sap-btn-primary" t-on-click="goCount"
                    t-att-disabled="state.products.length === 0">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                ถึงแล้ว! เริ่มนับ
            </button>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         SCREEN 3 — COUNT  (Object Page — Analytical Table)
    ══════════════════════════════════════════════════════════════════════ -->
    <div t-elif="state.screen === 'count'" class="sap-page"
         t-att-class="{'wms-scan-flash-ok': state.scanFlash === 'ok',
                       'wms-scan-flash-err': state.scanFlash === 'error'}">

        <input t-ref="scanInput" class="wms-count-scan-hidden"
               autocomplete="off" type="text" readonly="1"/>

        <div class="sap-shellbar">
            <button class="sap-shellbar-btn" t-on-click="goNavigate">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="sap-shellbar-logo">KOB WMS</div>
            <div class="sap-shellbar-title">นับสินค้า</div>
            <div class="sap-shellbar-spacer"/>
            <div class="sap-step-wrap">
                <span class="sap-step">1</span>
                <span class="sap-step-line sap-step-line-done"/>
                <span class="sap-step sap-step-on">2</span>
                <span class="sap-step-line"/>
                <span class="sap-step">3</span>
            </div>
        </div>

        <div t-if="currentProduct" class="sap-count-layout">

            <!-- Left: product card + progress -->
            <div class="sap-count-sidebar">
                <!-- Location breadcrumb -->
                <div class="sap-loc-strip">
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    <span t-esc="state.task.zone_code"/>
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    <span t-esc="state.task.rack_name"/>
                    <svg width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    <strong t-esc="state.task.location_name"/>
                </div>

                <!-- Product Object Header -->
                <div class="sap-product-card">
                    <div class="sap-product-card-label">สินค้า <t t-esc="progressLabel"/></div>
                    <div class="sap-progress-bar">
                        <div class="sap-progress-fill"
                             t-attf-style="width:{{ ((state.productIdx+1)/state.products.length*100).toFixed(0) }}%"/>
                    </div>
                    <div class="sap-product-card-sku" t-esc="currentProduct.product_code"/>
                    <div class="sap-product-card-name" t-esc="currentProduct.product_name"/>
                </div>

                <!-- Product pagination dots -->
                <div class="sap-dot-row">
                    <t t-foreach="state.products" t-as="p" t-key="p.product_id">
                        <span class="sap-dot" t-att-class="{'sap-dot-on': p_index === state.productIdx}"/>
                    </t>
                </div>

                <!-- Scan button -->
                <button class="sap-btn-scan" t-on-click="() => _focusScan()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M3 15h18M9 3v18"/></svg>
                    Scan Barcode
                </button>
            </div>

            <!-- Right: SAP Analytical Table -->
            <div class="sap-count-main">
                <!-- Table toolbar -->
                <div class="sap-toolbar">
                    <span class="sap-toolbar-title">
                        Lot / Serial Numbers
                        <span class="sap-count-badge"><t t-esc="currentProduct.lots.length"/></span>
                    </span>
                    <div class="sap-toolbar-actions">
                        <button class="sap-btn-toolbar" t-on-click="() => openLotPicker(currentProduct)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Lot
                        </button>
                        <button class="sap-btn-toolbar sap-btn-toolbar-ghost" t-on-click="() => addUnknownLot(currentProduct)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Unknown Lot
                        </button>
                    </div>
                </div>

                <!-- Analytical Table -->
                <div class="sap-table-wrap sap-table-count">
                    <table class="sap-table">
                        <thead>
                            <tr>
                                <th class="sap-th">Lot / Serial</th>
                                <th class="sap-th sap-ta-center" style="width:80px">ระบบมี</th>
                                <th class="sap-th sap-ta-center" style="width:160px">นับได้</th>
                                <th class="sap-th sap-ta-center" style="width:80px">ส่วนต่าง</th>
                                <th class="sap-th sap-ta-center" style="width:60px">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="currentProduct.lots" t-as="lot" t-key="lot._key"
                                class="sap-tr sap-tr-noclick"
                                t-att-class="{'sap-tr-error': lot.counted_qty !== lot.expected_qty,
                                              'sap-tr-ok':    lot.counted_qty === lot.expected_qty and lot.counted_qty > 0}">

                                <td class="sap-td">
                                    <div class="sap-lot-cell">
                                        <span class="sap-lot-name" t-esc="lot.lot_name"/>
                                        <span t-if="lot.lot_ref"      class="sap-lot-ref"    t-esc="lot.lot_ref"/>
                                        <span t-if="lot.expiry_date"  class="sap-lot-expiry">EXP: <t t-esc="lot.expiry_date"/></span>
                                        <span t-if="lot.lot_id===false" class="sap-badge-new">NEW</span>
                                    </div>
                                </td>

                                <td class="sap-td sap-ta-right sap-num-cell" t-esc="lot.expected_qty"/>

                                <td class="sap-td sap-ta-center">
                                    <div class="sap-qty-ctrl">
                                        <button class="sap-qty-btn" t-on-click="() => adjustQty(lot, -1)">−</button>
                                        <input class="sap-qty-input" type="number" min="0" step="1"
                                               t-att-value="lot.counted_qty"
                                               t-on-change="(ev) => setQty(lot, ev)"/>
                                        <button class="sap-qty-btn" t-on-click="() => adjustQty(lot, 1)">+</button>
                                    </div>
                                </td>

                                <td class="sap-td sap-ta-right">
                                    <span t-if="lot.counted_qty !== lot.expected_qty"
                                          class="sap-diff-val"
                                          t-att-class="{'sap-diff-pos': lot.counted_qty > lot.expected_qty,
                                                        'sap-diff-neg': lot.counted_qty &lt; lot.expected_qty}">
                                        <t t-if="lot.counted_qty - lot.expected_qty > 0">+</t>
                                        <t t-esc="lot.counted_qty - lot.expected_qty"/>
                                    </span>
                                    <span t-else="" class="sap-diff-zero">—</span>
                                </td>

                                <td class="sap-td sap-ta-center">
                                    <span t-if="lot.counted_qty === lot.expected_qty and lot.counted_qty > 0"
                                          class="sap-status-dot sap-status-ok" title="ถูกต้อง"/>
                                    <span t-elif="lot.counted_qty !== lot.expected_qty"
                                          class="sap-status-dot sap-status-err" title="พบส่วนต่าง"/>
                                    <span t-else=""
                                          class="sap-status-dot sap-status-pending" title="ยังไม่นับ"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Footer nav -->
                <div class="sap-count-footer">
                    <button class="sap-btn-secondary sap-btn-nav"
                            t-att-disabled="state.productIdx === 0"
                            t-on-click="prevProduct">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
                        ก่อนหน้า
                    </button>
                    <button class="sap-btn-primary sap-btn-nav" t-on-click="nextProduct">
                        <t t-if="state.productIdx &lt; state.products.length - 1">
                            ถัดไป
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                        </t>
                        <t t-else="">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                            สรุปผล
                        </t>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         SCREEN 4 — SUMMARY  (Analytical Table with totals row)
    ══════════════════════════════════════════════════════════════════════ -->
    <div t-elif="state.screen === 'summary'" class="sap-page">

        <div class="sap-shellbar">
            <button class="sap-shellbar-btn"
                    t-on-click="() => { state.productIdx = 0; state.screen = 'count'; }">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <div class="sap-shellbar-logo">KOB WMS</div>
            <div class="sap-shellbar-title">สรุปผลนับ</div>
            <div class="sap-shellbar-spacer"/>
            <div class="sap-step-wrap">
                <span class="sap-step">1</span>
                <span class="sap-step-line sap-step-line-done"/>
                <span class="sap-step">2</span>
                <span class="sap-step-line sap-step-line-done"/>
                <span class="sap-step sap-step-on">3</span>
            </div>
        </div>

        <!-- Done -->
        <div t-if="state.submitDone" class="sap-done">
            <div class="sap-done-ring">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <p class="sap-done-title">ส่งผลนับสำเร็จ</p>
            <p class="sap-done-sub">บันทึกใน Session เรียบร้อยแล้ว</p>
            <button class="sap-btn-primary" t-on-click="backAfterSubmit">กลับหน้าหลัก</button>
        </div>

        <div t-else="" class="sap-page-body">
            <!-- Object header -->
            <div class="sap-obj-header">
                <div class="sap-obj-breadcrumb">
                    <span t-esc="state.task.zone_code"/>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    <span t-esc="state.task.rack_name"/>
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
                    <strong t-esc="state.task.location_name"/>
                </div>
                <div class="sap-obj-title" t-esc="state.task.location_name"/>
                <!-- Variance KPI strip -->
                <div class="sap-kpi-strip"
                     t-att-class="{'sap-kpi-ok': totalVariance === 0, 'sap-kpi-err': totalVariance !== 0}">
                    <span class="sap-kpi-label">ส่วนต่างรวม</span>
                    <span class="sap-kpi-value">
                        <t t-if="totalVariance > 0">+</t><t t-esc="totalVariance"/> ชิ้น
                    </span>
                    <span class="sap-kpi-status">
                        <t t-if="totalVariance === 0">✓ ถูกต้อง</t>
                        <t t-else="">⚠ พบส่วนต่าง</t>
                    </span>
                </div>
            </div>

            <!-- Summary toolbar -->
            <div class="sap-toolbar">
                <span class="sap-toolbar-title">รายละเอียดการนับ</span>
            </div>

            <!-- Flat analytical table: all products + lots -->
            <div class="sap-table-wrap sap-table-flex">
                <table class="sap-table">
                    <thead>
                        <tr>
                            <th class="sap-th">SKU</th>
                            <th class="sap-th">สินค้า</th>
                            <th class="sap-th">Lot / Serial</th>
                            <th class="sap-th sap-ta-center" style="width:80px">ระบบมี</th>
                            <th class="sap-th sap-ta-center" style="width:80px">นับได้</th>
                            <th class="sap-th sap-ta-center" style="width:90px">ส่วนต่าง</th>
                            <th class="sap-th sap-ta-center" style="width:60px">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="state.products" t-as="p" t-key="p.product_id">
                            <t t-foreach="p.lots" t-as="lot" t-key="lot._key">
                                <tr class="sap-tr sap-tr-noclick"
                                    t-att-class="{'sap-tr-error': lot.counted_qty !== lot.expected_qty,
                                                  'sap-tr-ok':    lot.counted_qty === lot.expected_qty and lot.counted_qty > 0}">
                                    <!-- SKU: only on first lot of product -->
                                    <td class="sap-td">
                                        <span t-if="lot_index === 0" class="sap-mono" t-esc="p.product_code"/>
                                    </td>
                                    <td class="sap-td">
                                        <span t-if="lot_index === 0" class="sap-td-name" t-esc="p.product_name"/>
                                    </td>
                                    <td class="sap-td">
                                        <div class="sap-lot-cell">
                                            <span class="sap-lot-name" t-esc="lot.lot_name"/>
                                            <span t-if="lot.expiry_date" class="sap-lot-expiry">EXP: <t t-esc="lot.expiry_date"/></span>
                                        </div>
                                    </td>
                                    <td class="sap-td sap-ta-right sap-num-cell" t-esc="lot.expected_qty"/>
                                    <td class="sap-td sap-ta-right sap-num-cell sap-num-bold" t-esc="lot.counted_qty"/>
                                    <td class="sap-td sap-ta-right">
                                        <span t-if="lot.counted_qty !== lot.expected_qty"
                                              class="sap-diff-val"
                                              t-att-class="{'sap-diff-pos': lot.counted_qty > lot.expected_qty,
                                                            'sap-diff-neg': lot.counted_qty &lt; lot.expected_qty}">
                                            <t t-if="lot.counted_qty - lot.expected_qty > 0">+</t>
                                            <t t-esc="lot.counted_qty - lot.expected_qty"/>
                                        </span>
                                        <span t-else="" class="sap-diff-zero">—</span>
                                    </td>
                                    <td class="sap-td sap-ta-center">
                                        <span t-if="lot.counted_qty === lot.expected_qty and lot.counted_qty > 0"
                                              class="sap-status-dot sap-status-ok"/>
                                        <span t-elif="lot.counted_qty !== lot.expected_qty"
                                              class="sap-status-dot sap-status-err"/>
                                        <span t-else="" class="sap-status-dot sap-status-pending"/>
                                    </td>
                                </tr>
                            </t>
                        </t>
                    </tbody>
                    <!-- Grand total row -->
                    <tfoot>
                        <tr class="sap-tfoot-row">
                            <td class="sap-td sap-tfoot-label" colspan="3">รวมทั้งหมด</td>
                            <td class="sap-td sap-ta-right sap-num-cell sap-tfoot-num"/>
                            <td class="sap-td sap-ta-right sap-num-cell sap-tfoot-num"/>
                            <td class="sap-td sap-ta-right"
                                t-att-class="{'sap-diff-pos': totalVariance > 0,
                                              'sap-diff-neg': totalVariance &lt; 0,
                                              'sap-diff-zero': totalVariance === 0}">
                                <t t-if="totalVariance > 0">+</t>
                                <t t-if="totalVariance !== 0" t-esc="totalVariance"/>
                                <t t-if="totalVariance === 0">—</t>
                            </td>
                            <td class="sap-td"/>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="sap-obj-footer">
                <button class="sap-btn-primary sap-btn-submit"
                        t-att-class="{'sap-btn-loading': state.submitting}"
                        t-att-disabled="state.submitting"
                        t-on-click="submitCount">
                    <t t-if="state.submitting">
                        <span class="wms-count-spinner sap-spinner-sm"/>
                        กำลังส่ง…
                    </t>
                    <t t-else="">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        ส่งผลนับ
                    </t>
                </button>
            </div>
        </div>
    </div>

    <!-- ══════════════════════════════════════════════════════════════════
         LOT PICKER — SAP Dialog
    ══════════════════════════════════════════════════════════════════════ -->
    <div t-if="state.lotPicker.visible" class="sap-dialog-overlay" t-on-click="closeLotPicker">
        <div class="sap-dialog" t-on-click.stop="">

            <div class="sap-dialog-header">
                <span class="sap-dialog-title">
                    Select Lot —
                    <span t-esc="state.lotPicker.product and state.lotPicker.product.product_name"/>
                </span>
                <button class="sap-dialog-close" t-on-click="closeLotPicker">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>

            <div t-if="state.lotPicker.loading" class="sap-dialog-loading">
                <span class="wms-count-spinner"/>
                กำลังโหลด…
            </div>
            <div t-elif="state.lotPicker.results.length === 0" class="sap-no-data">
                <p>ไม่พบ Lot สำหรับสินค้านี้</p>
            </div>
            <div t-else="" class="sap-dialog-body">
                <table class="sap-table">
                    <thead>
                        <tr>
                            <th class="sap-th">Lot / Serial</th>
                            <th class="sap-th">Ref</th>
                            <th class="sap-th sap-ta-center">หมดอายุ</th>
                            <th class="sap-th sap-ta-right" style="width:80px">ระบบมี</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr t-foreach="state.lotPicker.results" t-as="lot" t-key="lot.lot_id"
                            class="sap-tr" t-on-click="() => pickLot(lot)">
                            <td class="sap-td"><span class="sap-lot-name" t-esc="lot.lot_name"/></td>
                            <td class="sap-td sap-mono sap-text-muted" t-esc="lot.lot_ref or '—'"/>
                            <td class="sap-td sap-ta-center">
                                <span t-if="lot.expiry_date" class="sap-lot-expiry" t-esc="lot.expiry_date"/>
                                <span t-else="" class="sap-text-muted">—</span>
                            </td>
                            <td class="sap-td sap-ta-right sap-num-cell"><strong t-esc="lot.qty"/></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
</t>

</templates>
