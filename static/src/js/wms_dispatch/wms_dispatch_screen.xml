<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════════
     WmsDispatchScreen — F4 Courier Dispatch
     Fields: wms.courier.batch  (state in draft/scanning)
             wms.scan.item      (barcode, order_ref, shop_name)
     ═══════════════════════════════════════════════════════════ -->
<t t-name="kob_wms.WmsDispatchScreen">
<div class="wms-screen">

    <WmsTopNav activeMode="activeMode" accentColor="accentColor"
               onNavigate="(m) => this.goToMode(m)" onBack="() => this.onClickBack()"/>

    <main class="wms-main">
        <div class="wms-page">

            <!-- ═══ COURIER PICKER MODAL ═══ -->
            <t t-if="state.showCourierPicker">
                <div style="position:fixed; inset:0; z-index:200; background:rgba(25,28,29,0.55); display:flex; align-items:center; justify-content:center;">
                    <div style="background:#fff; border-radius:16px; padding:28px 32px; min-width:320px; max-width:480px; width:90%; box-shadow:0 8px 40px rgba(0,0,0,0.18);">
                        <div style="font-family:'Manrope',sans-serif; font-size:16px; font-weight:800; color:var(--wms-on-surface); margin-bottom:6px;">
                            <i class="fa fa-truck me-2" style="color:var(--wms-primary-container);"/>Select Courier
                        </div>
                        <div style="font-size:12px; color:var(--wms-on-surface-variant); margin-bottom:20px;">
                            Choose the courier for this dispatch batch
                        </div>

                        <t t-if="state.couriers.length === 0">
                            <div class="text-center py-4 text-muted" style="font-size:13px;">
                                <i class="fa fa-exclamation-circle me-1"/>No couriers found.
                                Add couriers in <strong>Configuration → Couriers</strong>.
                            </div>
                        </t>
                        <div t-else="" style="display:flex; flex-direction:column; gap:8px; max-height:300px; overflow-y:auto;">
                            <button t-foreach="state.couriers" t-as="courier" t-key="courier.id"
                                    t-on-click="() => this.confirmCreateBatch(courier.id)"
                                    style="display:flex; align-items:center; gap:12px; padding:12px 16px; border-radius:10px; border:1.5px solid var(--wms-outline-variant); background:#fafafa; cursor:pointer; text-align:left; transition:background 0.12s, border-color 0.12s;">
                                <div style="width:36px; height:36px; border-radius:50%; background:var(--wms-primary-container); display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                    <i class="fa fa-truck" style="color:#fff; font-size:14px;"/>
                                </div>
                                <span style="font-size:14px; font-weight:600; color:var(--wms-on-surface);" t-esc="courier.name"/>
                            </button>
                        </div>

                        <button t-on-click="cancelCourierPicker"
                                style="margin-top:18px; width:100%; padding:10px; border-radius:8px; border:1px solid var(--wms-outline-variant); background:transparent; cursor:pointer; font-size:13px; color:var(--wms-on-surface-variant);">
                            Cancel
                        </button>
                    </div>
                </div>
            </t>

            <!-- ═══ QUEUE VIEW ═══ -->
            <t t-if="!state.currentBatch">
                <div class="wms-page-header">
                    <div>
                        <div class="wms-page-title">Courier Dispatch</div>
                        <div class="wms-page-subtitle">Scan batch barcode or select a manifest to load parcels</div>
                    </div>
                    <div class="wms-page-actions">
                        <button class="wms-btn-secondary" t-on-click="loadBatches">
                            <i class="fa fa-refresh me-1"/>Refresh
                        </button>
                        <button class="wms-btn-primary" t-on-click="createBatch">
                            <i class="fa fa-plus me-1"/>New Batch
                        </button>
                    </div>
                </div>

                <div class="wms-scan-panel">
                    <label class="wms-scan-panel-label">Scan Batch / Manifest Barcode</label>
                    <div class="wms-scan-field-wrap">
                        <i class="fa fa-barcode wms-scan-field-icon"/>
                        <input class="wms-scan-field" t-ref="scanInput"
                               placeholder="Scan manifest barcode or batch name…"
                               t-on-keydown="onScanKeydown"
                               autocomplete="off" inputmode="none"/>
                        <span class="wms-scan-badge wms-scan-badge-ready">Ready</span>
                    </div>
                    <div t-if="state.lastScan" class="wms-scan-feedback-row">
                        <span t-if="state.lastScanOk === true"  class="badge text-bg-success"><i class="fa fa-check"/> <t t-esc="state.lastScan"/></span>
                        <span t-elif="state.lastScanOk === false" class="badge text-bg-danger"><i class="fa fa-times"/> <t t-esc="state.lastScan"/></span>
                    </div>
                </div>

                <div class="wms-ledger-card">
                    <div class="wms-ledger-card-header">
                        <span>Active Batches</span>
                        <span class="wms-chip wms-chip-pending"><t t-esc="state.batches.length"/></span>
                    </div>
                    <t t-if="state.loading">
                        <div class="text-center py-5"><i class="fa fa-spinner fa-spin fa-2x text-muted"/></div>
                    </t>
                    <t t-elif="state.batches.length === 0">
                        <div class="text-center py-5 text-muted">
                            <i class="fa fa-paper-plane fa-2x mb-2 d-block"/>No active batches
                            <div class="mt-3">
                                <button class="wms-btn-primary" t-on-click="createBatch">
                                    <i class="fa fa-plus me-1"/>Create First Batch
                                </button>
                            </div>
                        </div>
                    </t>
                    <t t-else="">
                        <table class="wms-ledger-table">
                            <thead>
                                <tr>
                                    <th>Batch / Manifest</th>
                                    <th>Courier</th>
                                    <th class="align-center">Parcels</th>
                                    <th class="align-right">State</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.batches" t-as="batch" t-key="batch.id"
                                    t-on-click="() => this.selectBatch(batch)" style="cursor:pointer;">
                                    <td>
                                        <div style="font-weight:700; font-family:monospace; font-size:13px;"
                                             t-esc="batch.name"/>
                                        <div style="font-size:10px; color:var(--wms-on-surface-variant);">
                                            ID #<t t-esc="batch.id"/>
                                        </div>
                                    </td>
                                    <td style="font-size:12px;">
                                        <t t-if="batch.courier_id">
                                            <i class="fa fa-truck me-1 text-muted"/>
                                            <t t-esc="batch.courier_id[1]"/>
                                        </t>
                                        <span t-else="" class="text-muted">—</span>
                                    </td>
                                    <td class="align-center">
                                        <span class="wms-chip wms-chip-pending"
                                              style="font-family:monospace; font-weight:700;">
                                            <t t-esc="(batch.scan_item_ids || []).length"/>
                                        </span>
                                    </td>
                                    <td class="align-right">
                                        <span t-att-class="getBatchStateClass(batch.state)"
                                              style="font-size:10px; padding:3px 10px; border-radius:999px;"
                                              t-esc="batch.state"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                        <div class="wms-ledger-footer">
                            <span>Showing <t t-esc="state.batches.length"/> batches</span>
                        </div>
                    </t>
                </div>
            </t>

            <!-- ═══ DETAIL VIEW — batch selected ═══ -->
            <t t-if="state.currentBatch">
                <div class="wms-page-header">
                    <div>
                        <div class="wms-breadcrumb">
                            <span t-on-click="deselectBatch" style="cursor:pointer;">Dispatch</span>
                            <span class="wms-bc-sep">/</span>
                            <span class="wms-bc-active" t-esc="state.currentBatch.name"/>
                        </div>
                        <div class="wms-page-title">
                            Manifest: <t t-esc="state.currentBatch.name"/>
                        </div>
                        <div class="wms-page-subtitle">
                            <t t-if="state.currentBatch.courier_id">
                                <i class="fa fa-truck me-1"/>
                                <t t-esc="state.currentBatch.courier_id[1]"/>
                                <span class="mx-2">·</span>
                            </t>
                            <t t-esc="state.scanItems.length"/> parcels loaded
                        </div>
                    </div>
                    <div class="wms-page-actions">
                        <button class="wms-btn-secondary" t-on-click="deselectBatch">
                            <i class="fa fa-arrow-left me-1"/>All Batches
                        </button>
                    </div>
                </div>

                <div class="wms-bento-grid">

                    <!-- LEFT: scan + parcel list -->
                    <div class="wms-bento-left">

                        <div class="wms-scan-panel" style="margin-bottom:0; border-left-color:var(--wms-primary-container);">
                            <label class="wms-scan-panel-label">Scan AWB Barcode to Add to Manifest</label>
                            <div class="wms-scan-field-wrap">
                                <i class="fa fa-barcode wms-scan-field-icon"/>
                                <input class="wms-scan-field" t-ref="scanInput"
                                       placeholder="Scan AWB / parcel tracking barcode…"
                                       t-on-keydown="onScanKeydown"
                                       autocomplete="off" inputmode="none"/>
                                <span t-if="state.dispatching" class="wms-scan-badge wms-scan-badge-scanning">
                                    <span class="wms-dot me-1"/>Dispatching…
                                </span>
                                <span t-else="" class="wms-scan-badge wms-scan-badge-ready">Ready</span>
                            </div>
                            <div t-if="state.lastScan" class="wms-scan-feedback-row">
                                <span t-if="state.lastScanOk === true"  class="badge text-bg-success"><i class="fa fa-check"/> <t t-esc="state.lastScan"/></span>
                                <span t-elif="state.lastScanOk === false" class="badge text-bg-danger"><i class="fa fa-times"/> <t t-esc="state.lastScan"/></span>
                            </div>
                        </div>

                        <div class="wms-ledger-card">
                            <div class="wms-ledger-card-header">
                                <span>Parcel Manifest
                                    <span class="ms-2 wms-chip wms-chip-draft">
                                        <t t-esc="state.scanItems.length"/>
                                    </span>
                                </span>
                            </div>

                            <t t-if="state.scanItems.length === 0">
                                <div class="text-center py-5 text-muted">
                                    <i class="fa fa-inbox fa-2x mb-2 d-block"/>
                                    No parcels yet — ship orders from <strong>Outbound (F3)</strong>
                                    or scan AWB barcodes above
                                </div>
                            </t>
                            <t t-else="">
                                <table class="wms-ledger-table">
                                    <thead>
                                        <tr>
                                            <th style="width:36px;">#</th>
                                            <th>AWB Barcode</th>
                                            <th>Order Ref</th>
                                            <th class="align-right">Platform / Shop</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr t-foreach="state.scanItems" t-as="item" t-key="item.id">
                                            <td style="font-size:11px; color:var(--wms-on-surface-variant);">
                                                <t t-esc="item_index + 1"/>
                                            </td>
                                            <td>
                                                <span style="font-family:monospace; font-weight:700; font-size:13px; color:var(--wms-primary-container);"
                                                      t-esc="item.barcode"/>
                                            </td>
                                            <td>
                                                <span class="wms-chip wms-chip-staged"
                                                      style="font-family:monospace; font-size:11px;"
                                                      t-esc="item.order_ref || '—'"/>
                                            </td>
                                            <td class="align-right">
                                                <span t-if="item.shop_name"
                                                      class="wms-chip wms-chip-pending"
                                                      style="font-size:10px;"
                                                      t-esc="item.shop_name"/>
                                                <span t-else="" class="text-muted" style="font-size:11px;">—</span>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                                <div class="wms-ledger-footer">
                                    <span><t t-esc="state.scanItems.length"/> parcels in manifest</span>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- RIGHT: batch summary + dispatch -->
                    <div class="wms-bento-right">

                        <!-- Batch info card -->
                        <div class="wms-summary-card"
                             style="border-left-color:var(--wms-primary-container);">
                            <h3>Batch Summary</h3>
                            <div class="wms-summary-row">
                                <span class="label">Manifest</span>
                                <span style="font-family:monospace; font-weight:700; font-size:13px; color:var(--wms-primary-container);"
                                      t-esc="state.currentBatch.name"/>
                            </div>
                            <div class="wms-summary-row">
                                <span class="label">Courier</span>
                                <span class="value"
                                      t-esc="state.currentBatch.courier_id ? state.currentBatch.courier_id[1] : '—'"/>
                            </div>
                            <div class="wms-summary-row">
                                <span class="label">State</span>
                                <span t-att-class="getBatchStateClass(state.currentBatch.state)"
                                      style="font-size:11px; padding:3px 10px; border-radius:999px;"
                                      t-esc="state.currentBatch.state"/>
                            </div>
                            <div class="wms-summary-row">
                                <span class="label">Parcels</span>
                                <span class="value" style="font-weight:800; font-size:22px; color:var(--wms-primary-container);">
                                    <t t-esc="state.scanItems.length"/>
                                </span>
                            </div>
                        </div>

                        <!-- Dispatch action -->
                        <div style="background:white; border-radius:12px; padding:20px; box-shadow:0 1px 4px rgba(25,28,29,0.05);">
                            <h3 style="font-family:'Manrope',sans-serif; font-weight:700; font-size:14px; margin-bottom:14px;">
                                Dispatch Action
                            </h3>

                            <t t-if="state.scanItems.length === 0">
                                <div class="text-center py-3" style="font-size:12px; color:var(--wms-on-surface-variant);">
                                    <i class="fa fa-info-circle me-1"/>
                                    Add parcels to enable dispatch
                                </div>
                            </t>
                            <t t-else="">
                                <div class="p-3 rounded mb-3"
                                     style="background:var(--wms-surface-container-low); font-size:12px; color:var(--wms-on-surface-variant);">
                                    <i class="fa fa-check-circle me-1 text-success"/>
                                    <strong><t t-esc="state.scanItems.length"/> parcels</strong> ready for courier handover.
                                    This action will mark the batch as dispatched.
                                </div>
                            </t>

                            <button class="wms-btn-primary w-100 py-3"
                                    style="font-size:15px; font-weight:800;"
                                    t-att-disabled="state.scanItems.length === 0 or state.dispatching"
                                    t-on-click="dispatchBatch">
                                <t t-if="state.dispatching">
                                    <i class="fa fa-spinner fa-spin me-2"/>Dispatching…
                                </t>
                                <t t-else="">
                                    <i class="fa fa-paper-plane me-2"/>
                                    Dispatch <t t-esc="state.scanItems.length"/> Parcels
                                </t>
                            </button>
                        </div>

                        <!-- Steps guide -->
                        <div style="background:white; border-radius:12px; padding:20px; box-shadow:0 1px 4px rgba(25,28,29,0.05);">
                            <h3 style="font-family:'Manrope',sans-serif; font-weight:700; font-size:14px; margin-bottom:14px;">
                                How to Dispatch
                            </h3>
                            <div class="d-flex flex-column gap-3">
                                <div class="d-flex align-items-start gap-3">
                                    <span style="width:24px; height:24px; border-radius:50%; background:var(--wms-primary-container); color:white; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0;">1</span>
                                    <span style="font-size:12px; color:var(--wms-on-surface-variant);">Ship orders in Outbound (F3) → AWBs auto-populate here</span>
                                </div>
                                <div class="d-flex align-items-start gap-3">
                                    <span style="width:24px; height:24px; border-radius:50%; background:var(--wms-primary-container); color:white; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0;">2</span>
                                    <span style="font-size:12px; color:var(--wms-on-surface-variant);">Or scan AWB barcodes manually into this manifest</span>
                                </div>
                                <div class="d-flex align-items-start gap-3">
                                    <span style="width:24px; height:24px; border-radius:50%; background:var(--wms-primary-container); color:white; font-size:11px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0;">3</span>
                                    <span style="font-size:12px; color:var(--wms-on-surface-variant);">Press Dispatch → handover confirmed, batch closed</span>
                                </div>
                            </div>
                        </div>

                        <button class="wms-btn-secondary w-100" t-on-click="deselectBatch">
                            <i class="fa fa-arrow-left me-1"/>Back to Batch List
                        </button>
                    </div>

                </div>
            </t>

        </div>
    </main>

</div>
</t>

</templates>
