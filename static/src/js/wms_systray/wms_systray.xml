<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

<t t-name="kob_wms.WmsWorkerSystray">
    <!-- Render in all Odoo apps when worker is logged in -->
    <t t-if="state.inWms and isLoggedIn">
        <li class="o_nav_entry wms-systray-item"
            style="display:flex;align-items:center;gap:0;padding:0 4px;height:100%;">

            <!-- SAP HANA divider -->
            <span style="width:1px;height:20px;background:rgba(255,255,255,.15);margin-right:8px;"/>

            <!-- Avatar pill -->
            <div class="wms-hana-badge"
                 style="
                    display:flex;align-items:center;gap:6px;
                    background:rgba(0,184,212,.12);
                    border:1px solid rgba(0,184,212,.30);
                    border-radius:16px;
                    padding:3px 10px 3px 4px;
                    cursor:default;
                 ">

                <!-- Initials circle -->
                <div style="
                        width:22px;height:22px;border-radius:50%;
                        background:#00B8D4;
                        display:flex;align-items:center;justify-content:center;
                        font-size:10px;font-weight:700;color:#003B4C;
                        letter-spacing:.5px;flex-shrink:0;
                     ">
                    <t t-esc="initials"/>
                </div>

                <!-- Name + role -->
                <div style="display:flex;flex-direction:column;line-height:1.2;" class="d-none d-sm-flex">
                    <span style="font-size:12px;font-weight:600;color:#E0F7FA;letter-spacing:.2px;">
                        <t t-esc="workerName"/>
                    </span>
                    <span style="font-size:10px;color:#80DEEA;text-transform:uppercase;letter-spacing:.6px;">
                        <t t-esc="workerRole"/>
                    </span>
                </div>
            </div>

            <!-- SAP Fiori logout icon-button -->
            <button t-on-click="logout"
                    title="Logout Employee"
                    style="
                        background:none;border:none;cursor:pointer;
                        padding:4px 6px;margin-left:4px;
                        display:flex;align-items:center;justify-content:center;
                        border-radius:4px;
                        transition:background .15s;
                        color:rgba(255,255,255,.5);
                    "
                    onmouseover="this.style.background='rgba(0,184,212,.15)';this.style.color='#00B8D4'"
                    onmouseout="this.style.background='none';this.style.color='rgba(255,255,255,.5)'">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                    <polyline points="16 17 21 12 16 7"/>
                    <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
            </button>

            <!-- SAP HANA divider -->
            <span style="width:1px;height:20px;background:rgba(255,255,255,.15);margin-left:4px;"/>
        </li>
    </t>
</t>

</templates>
