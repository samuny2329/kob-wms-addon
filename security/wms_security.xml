<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_kob_wms" model="ir.module.category">
            <field name="name">KOB WMS</field>
            <field name="description">KOB WMS Pro access levels</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_wms_worker" model="res.groups">
            <field name="name">WMS / Worker</field>
            <field name="category_id" ref="module_category_kob_wms"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_wms_supervisor" model="res.groups">
            <field name="name">WMS / Supervisor</field>
            <field name="category_id" ref="module_category_kob_wms"/>
            <field name="implied_ids" eval="[(4, ref('group_wms_worker'))]"/>
        </record>

        <record id="group_wms_manager" model="res.groups">
            <field name="name">WMS / Manager</field>
            <field name="category_id" ref="module_category_kob_wms"/>
            <field name="implied_ids" eval="[(4, ref('group_wms_supervisor'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="group_wms_director" model="res.groups">
            <field name="name">WMS / Director</field>
            <field name="category_id" ref="module_category_kob_wms"/>
            <field name="implied_ids" eval="[(4, ref('group_wms_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>

    <!-- Record rules (noupdate=1 so admin can customize) -->
    <data noupdate="1">

        <!-- Workers: only own assessments -->
        <record id="rule_kpi_assessment_worker" model="ir.rule">
            <field name="name">KPI Assessment: worker sees own</field>
            <field name="model_id" ref="model_wms_kpi_assessment"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_wms_worker'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <!-- Supervisors: own + where they are supervisor -->
        <record id="rule_kpi_assessment_supervisor" model="ir.rule">
            <field name="name">KPI Assessment: supervisor sees supervised</field>
            <field name="model_id" ref="model_wms_kpi_assessment"/>
            <field name="domain_force">['|', ('user_id', '=', user.id), ('supervisor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_wms_supervisor'))]"/>
        </record>

        <!-- Managers: own + where they are asst_manager/manager -->
        <record id="rule_kpi_assessment_manager" model="ir.rule">
            <field name="name">KPI Assessment: manager sees managed</field>
            <field name="model_id" ref="model_wms_kpi_assessment"/>
            <field name="domain_force">['|', '|', '|', ('user_id', '=', user.id), ('asst_manager_id', '=', user.id), ('manager_id', '=', user.id), ('supervisor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_wms_manager'))]"/>
        </record>

        <!-- Directors: see all -->
        <record id="rule_kpi_assessment_director" model="ir.rule">
            <field name="name">KPI Assessment: director sees all</field>
            <field name="model_id" ref="model_wms_kpi_assessment"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_wms_director'))]"/>
        </record>

        <!-- Assessment Score: follow assessment rules via stored related -->
        <record id="rule_kpi_score_worker" model="ir.rule">
            <field name="name">KPI Score: worker sees own</field>
            <field name="model_id" ref="model_wms_kpi_assessment_score"/>
            <field name="domain_force">[('line_id.assessment_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_wms_worker'))]"/>
        </record>

        <record id="rule_kpi_score_supervisor" model="ir.rule">
            <field name="name">KPI Score: supervisor</field>
            <field name="model_id" ref="model_wms_kpi_assessment_score"/>
            <field name="domain_force">['|', ('line_id.assessment_id.user_id', '=', user.id), ('line_id.assessment_id.supervisor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_wms_supervisor'))]"/>
        </record>

        <record id="rule_kpi_score_director" model="ir.rule">
            <field name="name">KPI Score: director sees all</field>
            <field name="model_id" ref="model_wms_kpi_assessment_score"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_wms_director'))]"/>
        </record>

    </data>
</odoo>
